rsource "networking/wireguard/Kconfig"

config FORCE_HAS_SEGGER_RTT
	bool
	default y
	select HAS_SEGGER_RTT

config FORCE_RUST_SUPPORTED
	bool
	default y
	select RUST_SUPPORTED

config PROMPT_TZ_OFFSET_MINUTES
	int "Prompt clock timezone offset (minutes from UTC)"
	default -240

config FORCE_FILE_SYSTEM_SHELL
	bool
	default y
	depends on SHELL && FILE_SYSTEM
	select FILE_SYSTEM_SHELL

config ESP_SPIRAM
	default y if SOC_SERIES_ESP32S3

config ESP_SPIRAM_MEMTEST
	default y if SOC_SERIES_ESP32S3 && ESP_SPIRAM

config ESP_SPIRAM_HEAP_SIZE
	default 6291456 if BOARD_XIAO_ESP32S3

config ESP32_WIFI_IRAM_OPT
	default y if SOC_SERIES_ESP32S3 && WIFI_ESP32

config ESP32_WIFI_RX_IRAM_OPT
	default y if SOC_SERIES_ESP32S3 && WIFI_ESP32

config ESP32_WIFI_STA_RECONNECT
	default y if SOC_SERIES_ESP32S3 && WIFI_ESP32

choice SPIRAM_MODE
	default SPIRAM_MODE_OCT if BOARD_XIAO_ESP32S3
endchoice

choice ESPTOOLPY_FLASHMODE
	default ESPTOOLPY_FLASHMODE_QIO if BOARD_XIAO_ESP32S3
endchoice

choice ESPTOOLPY_FLASHFREQ
	default ESPTOOLPY_FLASHFREQ_40M if BOARD_XIAO_ESP32S3
endchoice

choice ESPTOOLPY_FLASHSIZE
	default ESPTOOLPY_FLASHSIZE_8MB if BOARD_XIAO_ESP32S3
endchoice

choice WIFI_USAGE_MODE
	default WIFI_USAGE_MODE_STA_AP if BOARD_XIAO_ESP32S3
endchoice
