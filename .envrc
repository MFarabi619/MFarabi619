#!/usr/bin/env bash

export DIRENV_WARN_TIMEOUT=10s
export ZELLIJ_AUTO_EXIT=true
export ZELLIJ_AUTO_ATTACH=true
export SOPS_DISABLE_VERSION_CHECK=true
# export PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=true

case "$(uname -s)" in
*BSD)
  mise v
  ;;
*)
  eval "$(devenv direnvrc)"
  #  export DEVENV_TUI=false
  use devenv

  PATH_add "$HOME/.cargo/bin"
  [[ "$(uname -s)" == "Darwin" ]] && PATH_add "$(brew --prefix rustup)/bin"

  source_env_if_exists "${ESPUP_EXPORT_FILE:-$HOME/export-esp.sh}"
  if has xtensa-esp-elf-gcc; then
    log_status "Espressif Rust toolchain ready 🦀"
  else
    log_error "xtensa-esp-elf-gcc not found — install with: espup install && direnv allow"
  fi

  for _gdb_dir in "$HOME"/.espressif/tools/xtensa-esp-elf-gdb/*/xtensa-esp-elf-gdb/bin; do
    [[ -d "$_gdb_dir" ]] && PATH_add "$_gdb_dir" && break
  done
  unset _gdb_dir

  watch_file secrets.yaml
  set -a
  eval "$(sops -d --input-type yaml --output-type dotenv secrets.yaml)"
  set +a
  env_vars_required \
    PULUMI_CONFIG_PASSPHRASE \
    CONFIG_WIREGUARD_LOCAL_PRIVATE_KEY
  ;;
esac
