[default]
log-strip       = true
exclude-devices = !("/dev/cu.usbmodem*,/dev/cu.ttyACM*")

[xiao]
log       = true
log-file  = tio.xiao.log
device    = /dev/cu.usbmodem101

[walter]
log       = true
log-file  = tio.walter.log
device    = /dev/cu.usbmodem1101

[stm32f3_disco]
log       = true
log-file  = tio.stm32f3_disco.log
device    = /dev/cu.usbmodem103

[ceratina]
log       = true
log-file  = tio.ceratina.log
device    =  /dev/cu.usbmodem1311101

[usb]
pattern   = ^usb([0-9]*)
device    = /dev/cu.usbmodem%m1
