[default]
log       = true
log-strip = true
baudrate  = 115200
exclude-devices = !("/dev/cu.usbmodem*,")

[xiao]
log-file  = xiao.log
device    = /dev/cu.usbmodem101

[walter]
log-file  = walter.log
device    = /dev/cu.usbmodem101

[usbmodem-%1]
pattern   = ^usbmodem-([0-9]+)$
device    = /dev/cu.usbmodem%m1
