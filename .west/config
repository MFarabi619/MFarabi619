[manifest]
path     = .
file     = west.yml

[zephyr]
base     = zephyr

[build]
sysbuild = true
pristine = auto
# https://docs.zephyrproject.org/latest/develop/west/build-flash-debug.html#configuration-options
# dir-fmt  = build/{app}
board    = xiao_esp32s3/esp32s3/procpu
# board    = esp32s3_devkitc/esp32s3/procpu
# cmake-args = "-C build.cmake" # https://docs.zephyrproject.org/latest/develop/west/build-flash-debug.html#permanent-cmake-arguments

[flash]
rebuild  = true

[alias]
# f        = flash --runner probe-rs
bw       = build --board walter/esp32s3/procpu
fw       = flash --port-filter serial=8C:BF:EA:8E:AC:28
fx       = flash --port-filter serial=D0:CF:13:54:27:18
ax       = attach --runner probe-rs

patch    = patch -l patches.yml
pl       = patch -l patches.yml list
pc       = patch -l patches.yml clean
pa       = patch -l patches.yml apply --roll-back
