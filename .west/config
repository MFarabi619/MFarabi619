[manifest]
path = .
file = manifest.yml

[zephyr]
base = zephyrproject/zephyr

[build]
pristine   = auto
# board      = qemu_riscv32
# cmake-args = -DCMAKE_EXPORT_COMPILE_COMMANDS=ON -DCMAKE_VERBOSE_MAKEFILE=ON

[flash]
rebuild = true

[alias]
menuconfig = build apps/firmware -p=never -t menuconfig

dt         = dtsh --preferences apps/firmware/dtsh/preferences.ini --theme apps/firmware/dtsh/theme.ini build/firmware/zephyr/zephyr.dts
