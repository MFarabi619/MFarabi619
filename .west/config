[manifest]
file = manifest.yml
path = apps/embedded

[zephyr]
base = zephyr

[build]
pristine = auto
sysbuild = false
guess-dir = runners
board = qemu_riscv32
dir-fmt = build/{board}

[flash]
rebuild = true

[alias]
p = patch -l ../../libs/firmware/patches/patches.yml -b ../../libs/firmware/patches
pc = p clean
pa = p apply --roll-back

menuconfig = build apps/embedded -p=never -t menuconfig

r  = build apps/embedded -t run
t  = build apps/embedded --extra-conf=test.conf -t run
tr = twister -T apps/embedded --inline-logs -c --log-level DEBUG

bw = build apps/embedded --sysbuild -b walter/esp32s3/procpu
# bx = build apps/embedded --sysbuild -b xiao_esp32s3/esp32s3/procpu
bx = build apps/embedded --sysbuild -b xiao_esp32s3/esp32s3/procpu/sense

fw = flash --esp-device hwgrep://D0:CF:13:54:27:18
# fx = flash --esp-device hwgrep://8C:BF:EA:8E:AC:28
fx = flash --esp-device hwgrep://CC:BA:97:16:2B:68 -d build/xiao_esp32s3/esp32s3/procpu/sense

mw = espressif monitor -p hwgrep://D0:CF:13:54:27:18
# mx = espressif monitor -p hwgrep://8C:BF:EA:8E:AC:28
mx = espressif monitor -p hwgrep://CC:BA:97:16:2B:68

ax = attach --runner probe-rs

dtw = dtsh --preferences libs/firmware/dtsh/preferences.ini --theme libs/firmware/dtsh/theme.ini build/walter/esp32s3/procpu/embedded/firmware/zephyr/zephyr.dts
dtx = dtsh --preferences libs/firmware/dtsh/preferences.ini --theme libs/firmware/dtsh/theme.ini build/xiao_esp32s3/esp32s3/procpu/sense/embedded/firmware/zephyr/zephyr.dts
