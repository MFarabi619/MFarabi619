diff --git a/zephyr-sys/build.rs b/zephyr-sys/build.rs
index 6b825d1..1630807 100644
--- a/zephyr-sys/build.rs
+++ b/zephyr-sys/build.rs
@@ -113,6 +113,40 @@ fn main() -> anyhow::Result<()> {
         // UART
         .allowlist_item_if("CONFIG_UART_.*", || options.contains("CONFIG_SERIAL"))
         .allowlist_function_if("uart_.*", || options.contains("CONFIG_SERIAL"))
+        // Networking core
+        .allowlist_function_if("net_.*", || options.contains("CONFIG_NETWORKING"))
+        .allowlist_item_if("NET_.*", || options.contains("CONFIG_NETWORKING"))
+        // Sockets
+        .allowlist_function_if("zsock_.*", || options.contains("CONFIG_NET_SOCKETS"))
+        // Connection manager
+        .allowlist_function_if("conn_mgr_.*", || options.contains("CONFIG_NET_CONNECTION_MANAGER"))
+        // Wireguard
+        .allowlist_function_if("wireguard_.*", || options.contains("CONFIG_WIREGUARD"))
+        .allowlist_item_if("WIREGUARD_.*", || options.contains("CONFIG_WIREGUARD"))
+        // Virtual interfaces (VPN, WireGuard, IPIP, VLAN)
+        .allowlist_function_if("virtual_.*", || options.contains("CONFIG_NET_L2_VIRTUAL"))
+        .allowlist_item_if("virtual_.*", || options.contains("CONFIG_NET_L2_VIRTUAL"))
+        // DNS
+        .allowlist_function_if("dns_.*", || options.contains("CONFIG_DNS_RESOLVER"))
+        .allowlist_item_if("DNS_.*", || options.contains("CONFIG_DNS_RESOLVER"))
+        // WiFi mgmt
+        .allowlist_function_if("wifi_.*", || options.contains("CONFIG_NET_L2_WIFI_MGMT"))
+        .allowlist_item_if("WIFI_.*", || options.contains("CONFIG_NET_L2_WIFI_MGMT"))
+        .allowlist_item_if("wifi_.*", || options.contains("CONFIG_NET_L2_WIFI_MGMT"))
+        // SNTP
+        .allowlist_function_if("sntp_.*", || options.contains("CONFIG_SNTP"))
+        .allowlist_item_if("SNTP_.*", || options.contains("CONFIG_SNTP"))
+        // Base64
+        .allowlist_function_if("base64_.*", || options.contains("CONFIG_BASE64"))
+        // PM device
+        .allowlist_function_if("pm_device_.*", || options.contains("CONFIG_PM_DEVICE"))
+        .allowlist_item_if("PM_DEVICE_.*", || options.contains("CONFIG_PM_DEVICE"))
+        // MCUboot
+        .allowlist_function_if("boot_.*", || options.contains("CONFIG_BOOTLOADER_MCUBOOT"))
+        // MCUmgr SMP UDP transport
+        .allowlist_function_if("smp_udp_.*", || options.contains("CONFIG_MCUMGR_TRANSPORT_UDP"))
+        // Init entry (SYS_INIT struct, in <zephyr/init.h> via kernel.h)
+        .allowlist_item("init_entry")
         // Generate
         .generate()
         .expect("Unable to generate bindings");
