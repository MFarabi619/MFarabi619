{
  "name": "DPTechnics Walter",
  "url": "https://quickspot.io/",
  "vendor": "DPTechnics",
  "frameworks": [
    "arduino",
    "espidf"
  ],
  "debug": {
    "openocd_target": "esp32s3.cfg"
  },
  "build": {
    "core": "esp32",
    "mcu": "esp32s3",
    "variant": "esp32s3",
    "flash_mode": "qio",
    "f_cpu": "240000000L",
    "f_flash": "80000000L",
    "arduino": {
      "ldscript": "esp32s3_out.ld",
      "partitions": "default_16MB.csv"
    },
    "extra_flags": [
      "-DBOARD_HAS_PSRAM",
      "-DARDUINO_USB_MODE=1",
      "-DARDUINO_ESP32S3_DEV",
      "-DARDUINO_RUNNING_CORE=1",
      "-DARDUINO_USB_CDC_ON_BOOT=1",
      "-DARDUINO_EVENT_RUNNING_CORE=1"
    ],
    "hwids": [
      [
        "0x303A",
        "0x1001"
      ]
    ]
  },
  "connectivity": [
    "wifi",
    "bluetooth"
  ],
  "upload": {
    "flash_size": "16MB",
    "maximum_ram_size": 327680,
    "maximum_size": 16777216,
    "require_upload_port": true,
    "speed": 460800
  }
}
