config WIFI_CREDENTIALS_AP_SSID
	string "Soft AP SSID"
	default "walter"

config WIFI_CREDENTIALS_AP_PASSWORD
	string "Soft AP WPA2 pre-shared key (empty = open AP)"
	default ""

config CELLULAR_ATTACH_TIMEOUT_MS
	int "Cellular attach timeout (milliseconds)"
	default 180000

source "Kconfig.zephyr"
