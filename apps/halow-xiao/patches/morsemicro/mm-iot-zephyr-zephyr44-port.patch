diff --git a/components/morse_sm/mmmbedtls/CMakeLists.txt b/components/morse_sm/mmmbedtls/CMakeLists.txt
new file mode 100644
index 0000000..9467aab
--- /dev/null
+++ b/components/morse_sm/mmmbedtls/CMakeLists.txt
@@ -0,0 +1,51 @@
+# Copyright 2026 Apidae Systems
+# SPDX-License-Identifier: Apache-2.0
+#
+# Build mm-iot's vendored mbedtls 3.6.2 as a standalone Zephyr library
+# so we don't depend on Zephyr 4.4's mbedtls 4.x (incompatible config).
+
+set(MMMBEDTLS_DIR ${MMIOT_ROOT}/framework/src/mbedtls)
+
+zephyr_library_named(mmmbedtls)
+
+set(src_crypto
+  aes.c aesni.c aesce.c aria.c asn1parse.c asn1write.c base64.c
+  bignum.c bignum_core.c bignum_mod.c bignum_mod_raw.c block_cipher.c
+  camellia.c ccm.c chacha20.c chachapoly.c cipher.c cipher_wrap.c
+  constant_time.c cmac.c ctr_drbg.c des.c dhm.c ecdh.c ecdsa.c ecjpake.c
+  ecp.c ecp_curves.c ecp_curves_new.c entropy.c entropy_poll.c error.c
+  gcm.c hkdf.c hmac_drbg.c lmots.c lms.c md.c md5.c memory_buffer_alloc.c
+  nist_kw.c oid.c padlock.c pem.c pk.c pk_ecc.c pk_wrap.c pkcs12.c
+  pkcs5.c pkparse.c pkwrite.c platform.c platform_util.c poly1305.c
+  psa_crypto.c psa_crypto_aead.c psa_crypto_cipher.c psa_crypto_client.c
+  psa_crypto_driver_wrappers_no_static.c psa_crypto_ecp.c psa_crypto_ffdh.c
+  psa_crypto_hash.c psa_crypto_mac.c psa_crypto_pake.c psa_crypto_rsa.c
+  psa_crypto_se.c psa_crypto_slot_management.c psa_crypto_storage.c
+  psa_its_file.c psa_util.c ripemd160.c rsa.c rsa_alt_helpers.c sha1.c
+  sha256.c sha512.c sha3.c threading.c timing.c version.c version_features.c
+)
+
+set(src_x509
+  pkcs7.c x509.c x509_create.c x509_crl.c x509_crt.c x509_csr.c
+  x509write.c x509write_crt.c x509write_csr.c
+)
+
+foreach(f ${src_crypto} ${src_x509})
+  zephyr_library_sources(${MMMBEDTLS_DIR}/library/${f})
+endforeach()
+
+zephyr_library_sources(${CMAKE_CURRENT_SOURCE_DIR}/entropy_zephyr.c)
+
+zephyr_include_directories(
+  ${MMMBEDTLS_DIR}/include
+  ${MMIOT_ROOT}/framework/morselib/include
+  ${CMAKE_CURRENT_SOURCE_DIR}/../hostap
+)
+
+zephyr_library_compile_definitions(
+  MBEDTLS_CONFIG_FILE="morse_mbedtls_config.h"
+)
+
+target_compile_definitions(mmmbedtls INTERFACE
+  MBEDTLS_CONFIG_FILE="morse_mbedtls_config.h"
+)
diff --git a/components/morse_sm/mmmbedtls/entropy_zephyr.c b/components/morse_sm/mmmbedtls/entropy_zephyr.c
new file mode 100644
index 0000000..9b79e20
--- /dev/null
+++ b/components/morse_sm/mmmbedtls/entropy_zephyr.c
@@ -0,0 +1,10 @@
+#include <stddef.h>
+#include <zephyr/random/random.h>
+
+int mbedtls_hardware_poll(void *data, unsigned char *output, size_t len, size_t *olen)
+{
+    (void)data;
+    sys_rand_get(output, len);
+    *olen = len;
+    return 0;
+}
