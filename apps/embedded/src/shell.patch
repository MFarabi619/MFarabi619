diff --git a/subsys/shell/shell.c b/subsys/shell/shell.c
index d7a08c9a5ab..1be288aa5e1 100644
--- a/subsys/shell/shell.c
+++ b/subsys/shell/shell.c
@@ -2107,20 +2107,21 @@ int shell_prompt_change(const struct shell *sh, const char *prompt)
 		return -EINVAL;
 	}
 
-	size_t prompt_length = z_shell_strlen(prompt);
+	size_t prompt_bytes = strlen(prompt);
+	size_t prompt_visible = z_shell_strlen(prompt);
 
 	if (!z_shell_trylock(sh, SHELL_TX_MTX_TIMEOUT)) {
 		return -EBUSY;
 	}
 
-	if (prompt_length + 1 > CONFIG_SHELL_PROMPT_BUFF_SIZE) {
