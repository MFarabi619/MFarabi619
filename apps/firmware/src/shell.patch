diff --git a/subsys/shell/shell_utils.h b/subsys/shell/shell_utils.h
index 0af5d7d68cc..1c7dbeb553a 100644
--- a/subsys/shell/shell_utils.h
+++ b/subsys/shell/shell_utils.h
@@ -33,7 +33,31 @@ void z_shell_multiline_data_calc(struct shell_multiline_cons *cons,
 
 static inline uint16_t z_shell_strlen(const char *str)
 {
-	return str == NULL ? 0U : (uint16_t)strlen(str);
+	if (str == NULL) {
+		return 0U;
+	}
+
+	uint16_t visible = 0U;
+	const unsigned char *p = (const unsigned char *)str;
+
+	while (*p != '\0') {
+		if (*p == 0x1B && *(p + 1) == '[') {
+			p += 2;
+			while (*p != '\0' && (*p < 0x40 || *p > 0x7E)) {
+				p++;
+			}
+			if (*p != '\0') {
+				p++;
+			}
+			continue;
+		}
+		if ((*p & 0xC0) != 0x80) {
+			visible++;
+		}
+		p++;
+	}
+
+	return visible;
 }
 
