+/// Returns `true` if invoked from a Zephyr CMake build (ZEPHYR_BASE env
+/// var set by the CMake wrapper). When `false`, build scripts should skip
+/// their Zephyr-specific work so `cargo metadata` / `cargo check` / IDE
+/// indexing / non-Zephyr bins in the same package compile without panicking.
+pub fn is_zephyr_cmake_context() -> bool {
+    env::var("ZEPHYR_BASE").is_ok()
