 use bindgen::Builder;
 
 fn main() -> anyhow::Result<()> {
+    // Skip when not invoked from Zephyr CMake (e.g. host-side `cargo check`,
+    // IDE indexing, host bins in the same package as the Zephyr lib). Writes
+    // an empty bindings.rs so `include!()` in zephyr-sys/src/lib.rs succeeds;
+    // any user code referencing FFI types fails at compile time with a clear
+    // "unresolved item" error instead of a build-script panic here.
+    if env::var("ZEPHYR_BASE").is_err() {
+        println!(
+            "cargo:warning=zephyr-sys: ZEPHYR_BASE unset \u{2014} skipping \
+             bindgen. Build only valid for cargo metadata/check, not actual \
+             code generation."
+        );
+        let out_path = PathBuf::from(env::var("OUT_DIR").expect("missing output directory"));
+        std::fs::File::create(out_path.join("bindings.rs"))
+            .expect("write empty bindings.rs stub");
+        return Ok(());
+    }
+
     // Determine which version of Clang we linked with.
     let version = bindgen::clang_version();
