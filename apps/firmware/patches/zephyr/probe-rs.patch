+            self.check_call_ignore_sigint(server_args)
+            return
+
+        if self.gdb_cmd is None:
+            raise ValueError('Cannot debug; gdb is missing')
+
+        # Spawn gdb ourselves instead of using probe-rs gdb --gdb, so that
+        # --gdb-init-file (-x) and any future trailing gdb args don't get
